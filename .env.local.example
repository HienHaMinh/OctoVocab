# ============================================================
# SUPABASE
# Lấy từ: https://app.supabase.com → Project Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # NEVER expose to client

# ============================================================
# GOOGLE AI (Gemini — OCR verification + CEFR + translation)
# Lấy từ: https://aistudio.google.com/apikey
# ============================================================
GOOGLE_AI_API_KEY=your-google-ai-key-here

# ============================================================
# MISTRAL (Main OCR — scanned PDF extraction)
# Lấy từ: https://console.mistral.ai/api-keys
# ============================================================
MISTRAL_API_KEY=your-mistral-key-here

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Production: https://your-domain.vercel.app
